{
  "name": "divi-apex27/property-search",
  "version": "1.0.0",
  "apiVersion": 2,
  "title": "Apex27 Property Search",
  "titles": "Apex27 Property Searches",
  "moduleIcon": "divi/module-search",
  "moduleClassName": "divi-apex27-property-search",
  "moduleOrderClassName": "divi_apex27_property_search",
  "category": "module",
  "visualBuilderScript": "divi-apex27-builder",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "settings": {
        "meta": {
          "meta": {}
        },
        "advanced": {
          "html": {},
          "link": {},
          "text": {},
          "loop": {}
        },
        "decoration": {
          "animation": {},
          "attributes": {},
          "background": {},
          "border": {},
          "boxShadow": {},
          "conditions": {},
          "disabledOn": {},
          "filters": {},
          "interactions": {},
          "overflow": {},
          "order": {},
          "position": {},
          "scroll": {},
          "sizing": {},
          "spacing": {},
          "sticky": {},
          "transform": {},
          "transition": {},
          "zIndex": {}
        }
      }
    },
    "apex27": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "content": {
          "title": { "desktop": { "value": "Property Search" } },
          "type": { "desktop": { "value": "rent" } },
          "property_type": { "desktop": { "value": "flat" } },
          "overseas": { "desktop": { "value": "0" } },
          "min_price": { "desktop": { "value": "" } },
          "max_price": { "desktop": { "value": "" } },
          "city": { "desktop": { "value": "" } },
          "min_beds": { "desktop": { "value": "" } },
          "max_beds": { "desktop": { "value": "" } },
          "sort": { "desktop": { "value": "highest_price" } },
          "button_text": { "desktop": { "value": "Update" } },
          "show_results": { "desktop": { "value": "on" } },
          "empty_text": { "desktop": { "value": "No properties found." } }
        }
      },
      "settings": {
        "content": {
          "title": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.title",
              "priority": 5,
              "render": true,
              "label": "Title",
              "component": { "name": "divi/text", "type": "field" }
            }
          },
          "type": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.type",
              "priority": 10,
              "render": true,
              "label": "Type",
              "component": {
                "name": "divi/select",
                "type": "field",
                "props": {
                  "options": {
                    "sale": { "label": "Sales" },
                    "rent": { "label": "Lettings" }
                  }
                }
              }
            }
          },
          "property_type": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.property_type",
              "priority": 20,
              "render": true,
              "label": "Property Type",
              "component": { "name": "divi/text", "type": "field" }
            }
          },
          "overseas": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.overseas",
              "priority": 30,
              "render": true,
              "label": "UK / Overseas",
              "component": {
                "name": "divi/select",
                "type": "field",
                "props": {
                  "options": {
                    "0": { "label": "UK" },
                    "1": { "label": "Overseas" }
                  }
                }
              }
            }
          },
          "min_price": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.min_price",
              "priority": 40,
              "render": true,
              "label": "Min. Price",
              "component": { "name": "divi/text", "type": "field" }
            }
          },
          "max_price": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.max_price",
              "priority": 50,
              "render": true,
              "label": "Max. Price",
              "component": { "name": "divi/text", "type": "field" }
            }
          },
          "city": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.city",
              "priority": 60,
              "render": true,
              "label": "Location",
              "component": { "name": "divi/text", "type": "field" }
            }
          },
          "min_beds": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.min_beds",
              "priority": 70,
              "render": true,
              "label": "Min. Bedrooms",
              "component": { "name": "divi/text", "type": "field" }
            }
          },
          "max_beds": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.max_beds",
              "priority": 80,
              "render": true,
              "label": "Max. Bedrooms",
              "component": { "name": "divi/text", "type": "field" }
            }
          },
          "sort": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.sort",
              "priority": 90,
              "render": true,
              "label": "Sort",
              "component": {
                "name": "divi/select",
                "type": "field",
                "props": {
                  "options": {
                    "highest_price": { "label": "Highest price first" },
                    "lowest_price": { "label": "Lowest price first" },
                    "newest": { "label": "Newest first" }
                  }
                }
              }
            }
          },
          "button_text": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.button_text",
              "priority": 100,
              "render": true,
              "label": "Button Text",
              "component": { "name": "divi/text", "type": "field" }
            }
          },
          "show_results": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.show_results",
              "priority": 110,
              "render": true,
              "label": "Show Results",
              "component": { "name": "divi/toggle", "type": "field" }
            }
          },
          "empty_text": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "searchFields",
              "attrName": "apex27.content.empty_text",
              "priority": 120,
              "render": true,
              "label": "Empty Text",
              "component": { "name": "divi/text", "type": "field" }
            }
          }
        }
      }
    }
  },
  "customCssFields": {},
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "searchFields": {
        "panel": "content",
        "priority": 10,
        "groupName": "mainContent",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Search Fields"
          }
        }
      }
    }
  }
}
