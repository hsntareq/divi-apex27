{
    "name": "divi-apex27/property-for-sale",
    "version": "1.0.2",
    "apiVersion": 2,
    "title": "Apex27 Available For Sale",
    "titles": "Apex27 Available For Sale",
    "moduleIcon": "divi/module-search",
    "moduleClassName": "divi-apex27-property-for-sale",
    "moduleOrderClassName": "divi_apex27_property_for_sale",
    "category": "module",
    "visualBuilderScript": "divi-apex27-builder",
    "attributes": {
        "module": {
            "type": "object",
            "selector": "{{selector}}",
            "settings": {
                "meta": {
                    "meta": {}
                },
                "advanced": {
                    "html": {},
                    "link": {},
                    "text": {},
                    "loop": {}
                },
                "decoration": {
                    "animation": {},
                    "attributes": {},
                    "background": {},
                    "border": {},
                    "boxShadow": {},
                    "conditions": {},
                    "disabledOn": {},
                    "filters": {},
                    "interactions": {},
                    "overflow": {},
                    "order": {},
                    "position": {},
                    "scroll": {},
                    "sizing": {},
                    "spacing": {},
                    "sticky": {},
                    "transform": {},
                    "transition": {},
                    "zIndex": {}
                }
            }
        },
        "apex27": {
            "type": "object",
            "selector": "{{selector}}",
            "default": {
                "content": {
                    "title": {
                        "desktop": {
                            "value": "Available For Sale"
                        }
                    },
                    "listing_type": {
                        "desktop": {
                            "value": "listings"
                        }
                    },
                    "type": {
                        "desktop": {
                            "value": "sale"
                        }
                    },
                    "include_sstc": {
                        "desktop": {
                            "value": "0"
                        }
                    },
                    "row_count": {
                        "desktop": {
                            "value": "2"
                        }
                    },
                    "show_pagination": {
                        "desktop": {
                            "value": "on"
                        }
                    },
                    "column_count": {
                        "desktop": {
                            "value": "4"
                        }
                    },
                    "empty_text": {
                        "desktop": {
                            "value": "No available for sale properties found."
                        }
                    }
                }
            },
            "settings": {
                "content": {
                    "title": {
                        "groupType": "group-item",
                        "item": {
                            "groupSlug": "saleFields",
                            "attrName": "apex27.content.title",
                            "priority": 5,
                            "render": true,
                            "label": "Title",
                            "component": {
                                "name": "divi/text",
                                "type": "field"
                            }
                        }
                    },
                    "column_count": {
                        "groupType": "group-item",
                        "item": {
                            "groupSlug": "saleFields",
                            "attrName": "apex27.content.column_count",
                            "priority": 10,
                            "render": true,
                            "label": "Columns",
                            "component": {
                                "name": "divi/select",
                                "type": "field",
                                "props": {
                                    "options": {
                                        "1": { "label": "1" },
                                        "2": { "label": "2" },
                                        "3": { "label": "3" },
                                        "4": { "label": "4" },
                                        "5": { "label": "5" },
                                        "6": { "label": "6" }
                                    }
                                }
                            }
                        }
                    },
                    "row_count": {
                        "groupType": "group-item",
                        "item": {
                            "groupSlug": "saleFields",
                            "attrName": "apex27.content.row_count",
                            "priority": 12,
                            "render": true,
                            "label": "Rows",
                            "component": {
                                "name": "divi/select",
                                "type": "field",
                                "props": {
                                    "options": {
                                        "1": { "label": "1" },
                                        "2": { "label": "2" },
                                        "3": { "label": "3" },
                                        "4": { "label": "4" },
                                        "5": { "label": "5" },
                                        "6": { "label": "6" }
                                    }
                                }
                            }
                        }
                    },
                    "show_pagination": {
                        "groupType": "group-item",
                        "item": {
                            "groupSlug": "saleFields",
                            "attrName": "apex27.content.show_pagination",
                            "priority": 14,
                            "render": true,
                            "label": "Show Pagination",
                            "component": {
                                "name": "divi/toggle",
                                "type": "field"
                            }
                        }
                    },
                    "empty_text": {
                        "groupType": "group-item",
                        "item": {
                            "groupSlug": "saleFields",
                            "attrName": "apex27.content.empty_text",
                            "priority": 30,
                            "render": true,
                            "label": "Empty Text",
                            "component": {
                                "name": "divi/text",
                                "type": "field"
                            }
                        }
                    }
                }
            }
        }
    },
    "customCssFields": {},
    "settings": {
        "content": "auto",
        "design": "auto",
        "advanced": "auto",
        "groups": {
            "saleFields": {
                "panel": "content",
                "priority": 10,
                "groupName": "mainContent",
                "component": {
                    "name": "divi/composite",
                    "props": {
                        "groupLabel": "Available For Sale"
                    }
                }
            }
        }
